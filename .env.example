TELEGRAM_BOT_TOKEN=123456:ABCDEF_your_bot_token
TELEGRAM_CHAT_ID=123456789

# Optional
SCAN_INTERVAL_SECONDS=300

# Kac parite analiz edilsin. 0 = sinirsiz, hacim filtresini gecen TUM Binance
# Futures USDT-M pariteleri taranir. Belirli bir sayida sinirlamak isterseniz
# (orn. 80) buraya yazabilirsiniz, ama o zaman sadece en yuksek hacimli o kadar
# parite taranir ve digerleri hic degerlendirilmez.
MAX_SYMBOLS_TO_ANALYZE=0

MIN_QUOTE_VOLUME_USDT=50000000
MIN_CONFIDENCE=82
SIGNAL_COOLDOWN_MINUTES=240

# Aynı coin icin 24 saatte en fazla kac sinyal gonderilsin (yon farketmeksizin)
MAX_SIGNALS_PER_SYMBOL_PER_DAY=2

# TP1/TP2/Stop Loss kontrolu kac saniyede bir yapilsin. Bu kontrol ayri bir
# thread'de calisir, tarama ne kadar surerse sursun bu araliktan gecikmez.
POSITION_CHECK_INTERVAL_SECONDS=15

# Otomatik taramalarda "yeni sinyal yok" mesaji atilsin mi (true/false).
# false = sadece /scan komutuyla manuel taramada bilgi mesaji gelir.
ANNOUNCE_EMPTY_SCANS=false

BINANCE_TIMEOUT_SECONDS=12
LOG_LEVEL=INFO
